{
  "permissions": {
    "allow": [
      "Read(//h/DEV/projects/anjuna-.project/**)",
      "Bash(grep -E \"\\\\.\\(ts|tsx|js\\)$\")",
      "Bash(grep -E \"\\\\.\\(sql|ts|json\\)$\")",
      "Bash(xargs grep *)",
      "Bash(npm ls *)",
      "mcp__claude_ai_Supabase__list_tables",
      "mcp__claude_ai_Supabase__apply_migration",
      "Bash(pkill -f \"npm run dev\")",
      "Bash(curl -s http://localhost:5173)",
      "Bash(npx playwright *)",
      "Bash(curl -s http://localhost:5173 -o /dev/null -w \"%{http_code}\")"
    ],
    "additionalDirectories": [
      "\\tmp",
      "h:\\tmp"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.wolf/hooks/session-start.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.wolf/hooks/pre-read.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.wolf/hooks/pre-write.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.wolf/hooks/post-read.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.wolf/hooks/post-write.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.wolf/hooks/stop.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "understand-anything@understand-anything": true
  }
}
