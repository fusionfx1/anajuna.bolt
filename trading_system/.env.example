# ─────────────────────────────────────────────────────────────────────────────
# trading_system/.env.example
#
# Copy this file to trading_system/.env (or project root .env) and fill in
# your values. NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard URL and anonymous key (same as frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service-role key for server-side inserts (bypasses RLS)
# Required for agent_decisions persistence
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OANDA Broker ──────────────────────────────────────────────────────────────
OANDA_ACCOUNT_ID=your-account-id
OANDA_API_TOKEN=your-api-token
OANDA_ACCOUNT_TYPE=practice           # practice | live

# ── Signal mode ───────────────────────────────────────────────────────────────
SIGNAL_MODE=rules                     # rules | agent
                                      # "agent" activates CrewAI / KronosOrchestrator

# ── Agent layer ───────────────────────────────────────────────────────────────
# LangGraph supervisor (Phase 2)
USE_LANGGRAPH=0                       # 0 | 1

# Per-agent deadline (milliseconds)
AGENT_TIMEOUT_MS_PER_CALL=1500

# Total budget for all agents in one gather cycle (milliseconds)
AGENT_BUDGET_MS=4000

# ── Vector memory (Phase 2) ───────────────────────────────────────────────────
USE_PGVECTOR=1                        # 0 | 1  — disable if pgvector not installed
MEMORY_TOP_K=5                        # number of similar past decisions to retrieve

# ── LLM (for agent reasoning + embeddings) ────────────────────────────────────
OPENAI_API_KEY=sk-...                 # Required for LLM bias scoring + embeddings
                                      # Model used: gpt-4o-mini (news bias)
                                      # Embedding model: text-embedding-3-small

# ── News data provider (pick one, priority: NewsAPI → Finnhub → AlphaVantage) ─
NEWS_API_KEY=your-newsapi-key         # https://newsapi.org
FINNHUB_API_KEY=your-finnhub-key      # https://finnhub.io (also used for sentiment)
ALPHA_VANTAGE_API_KEY=your-av-key     # https://www.alphavantage.co

# ── Macro data (FRED) ─────────────────────────────────────────────────────────
FRED_API_KEY=your-fred-key            # https://fred.stlouisfed.org/docs/api/

# ── Sentiment data (pick one) ─────────────────────────────────────────────────
SENTIMENT_API_KEY=your-key            # Generic: uses Finnhub sentiment endpoint
TWITTER_BEARER_TOKEN=your-token       # Twitter v2 API recent search

# ── CrewAI full kickoff (optional, expensive) ─────────────────────────────────
USE_CREWAI_KICKOFF=0                  # 0 | 1  — enables full Crew.kickoff() with LLM
