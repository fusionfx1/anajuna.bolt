# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OANDA API (required for live forex trading)
# Account ID found in OANDA dashboard under Account > Account Summary
VITE_OANDA_ACCOUNT_ID=your-account-id
# Generate at: OANDA fxTrade > My Account > Manage API Access
VITE_OANDA_ACCESS_TOKEN=your-access-token
# Use practice URL for paper trading, fxtrade URL for live
VITE_OANDA_BASE_URL=https://api-fxpractice.oanda.com

# Optional: Polygon.io data feed
VITE_POLYGON_API_KEY=

# Optional: Alpaca broker
VITE_ALPACA_KEY_ID=
VITE_ALPACA_SECRET_KEY=
